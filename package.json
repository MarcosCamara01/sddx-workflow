{
  "name": "sddguard",
  "version": "0.11.0",
  "description": "Spec-Driven Development CLI — installs an SDD system in any project",
  "keywords": [
    "sdd",
    "spec-driven",
    "ai",
    "claude",
    "cursor",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcosCamara01/sddguard.git"
  },
  "homepage": "https://github.com/MarcosCamara01/sddguard#readme",
  "bugs": {
    "url": "https://github.com/MarcosCamara01/sddguard/issues"
  },
  "bin": {
    "sddguard": "dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "dev": "tsup --watch",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "npm run check && npm run build && node --test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
